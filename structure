CREATE TABLE p_users (
  uid CHAR(36)
    CHARACTER SET ascii
    COLLATE ascii_general_ci
    PRIMARY KEY,

  full_name VARCHAR(100) NOT NULL,

  email VARCHAR(100) NOT NULL UNIQUE,

  password VARCHAR(255) NOT NULL,

  created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,

  INDEX idx_users_email (email)
) ENGINE=InnoDB
  DEFAULT CHARSET=utf8mb4
  COLLATE=utf8mb4_unicode_ci;


CREATE TABLE p_oauth_tokens (
  uid CHAR(36)
    CHARACTER SET ascii
    COLLATE ascii_general_ci
    PRIMARY KEY,

  access_token VARCHAR(512) NOT NULL,
  access_token_expires_on DATETIME NOT NULL,

  refresh_token VARCHAR(512) NOT NULL,
  refresh_token_expires_on DATETIME NOT NULL,

  user_uid CHAR(36)
    CHARACTER SET ascii
    COLLATE ascii_general_ci
    NOT NULL,

  client_id VARCHAR(100) NOT NULL,

  created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,

  INDEX idx_oauth_user_uid (user_uid),
  INDEX idx_oauth_access_token (access_token),
  INDEX idx_oauth_refresh_token (refresh_token),

  CONSTRAINT fk_oauth_user
    FOREIGN KEY (user_uid)
    REFERENCES p_users (uid)
    ON DELETE CASCADE
) ENGINE=InnoDB
  DEFAULT CHARSET=utf8mb4
  COLLATE=utf8mb4_unicode_ci;
